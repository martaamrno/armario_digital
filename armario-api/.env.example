# Base de datos (Azure SQL en producción, SQLite para pruebas locales)
DATABASE_URL=mssql+pyodbc://usuario:password@servidor.database.windows.net/armario_db?driver=ODBC+Driver+18+for+SQL+Server

# JWT
SECRET_KEY=cambia_esto_por_un_valor_seguro
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_NAME=prendastorage
AZURE_STORAGE_ACCOUNT_KEY=tu_storage_key_aqui
AZURE_STORAGE_CONTAINER_NAME=prendascontainer

# Azure OpenAI (GPT-4o)
AZURE_OPENAI_ENDPOINT=https://<tu-recurso>.openai.azure.com
AZURE_OPENAI_API_KEY=tu_openai_api_key_aqui
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-5.4-pro-1
AZURE_OPENAI_DEPLOYMENT_VISION=gpt-5.4-pro-1

# Azure OpenAI — imagen (gpt-image-2, recurso separado)
AZURE_IMAGE_ENDPOINT=https://<tu-recurso-imagen>.services.ai.azure.com
AZURE_IMAGE_API_KEY=tu_image_api_key_aqui
AZURE_IMAGE_DEPLOYMENT=gpt-image-2-1
